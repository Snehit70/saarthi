{
  "name": "saarthi",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.1.2",
  "type": "module",
  "description": "Local Hyprland CLI for window control and screenshots",
  "bin": {
    "saarthi": "dist/src/cli.js"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc -p tsconfig.json && chmod +x dist/src/cli.js",
    "dev": "tsx src/cli.ts",
    "start": "node dist/src/cli.js",
    "overlay": "overlay/saarthi-overlay",
    "overlay:demo": "overlay/saarthi-overlay --demo",
    "overlay:install": "scripts/install-overlay-service.sh",
    "test": "vitest run",
    "smoke": "npm run build && node dist/scripts/cli-smoke.js",
    "smoke:screenshot": "npm run build && node dist/src/cli.js screenshot capture --target full --json"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^2.1.9"
  }
}
