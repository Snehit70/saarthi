[Unit]
Description=Saarthi overlay HUD
After=graphical-session.target

[Service]
Type=simple
WorkingDirectory=/home/snehit/projects/saarthi
ExecStart=/home/snehit/projects/saarthi/overlay/saarthi-overlay
Restart=on-failure
RestartSec=1

# Keep logs in user journal for quick debugging.
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=default.target
